{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'newsletter-section.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer-custom {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .footer-custom {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% stylesheet %}
  .footer-custom {
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
  }

  .footer-custom__outer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  @media screen and (min-width: 750px) {
    .footer-custom__outer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
    }
  }

  .footer-custom__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  @media screen and (max-width: 749px) {
    .footer-custom__grid {
      grid-template-columns: 1fr;
      gap: 3.2rem;
    }
  }

  .footer-custom__heading {
    font-size: 1.6rem;
    font-weight: 400;
    margin: 0 0 2rem;
    letter-spacing: 0.01em;
  }

  .footer-custom__content {
    font-size: 1.3rem;
    line-height: 1.9;
  }

  .footer-custom__content p {
    margin: 0;
  }

  .footer-custom__content p + p {
    margin-top: 0.8rem;
  }

  .footer-custom__address-wrapper {
    display: flex;
    gap: 0.8rem;
  }

  .footer-custom__address-icon {
    flex-shrink: 0;
    margin-top: 0.2rem;
  }

  .footer-custom__menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-custom__menu li {
    margin-bottom: 1.2rem;
  }

  .footer-custom__menu li:last-child {
    margin-bottom: 0;
  }

  .footer-custom__menu-link {
    text-decoration: none;
    font-size: 1.4rem;
    color: inherit;
  }

  .footer-custom__menu-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-custom__link {
    display: inline-block;
    margin-top: 1.6rem;
    font-size: 1.4rem;
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-custom__newsletter {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .footer-custom__newsletter .newsletter-form {
    align-items: flex-start;
    margin: 0;
  }

  .footer-custom__newsletter .newsletter-form__field-wrapper {
    max-width: 36rem;
  }

  .footer-custom__newsletter .newsletter__subheading {
    margin-left: 0;
    margin-right: 0;
  }

  .footer-custom__newsletter h2 {
    font-size: 1.6rem;
    font-weight: 400;
    margin: 0 0 2rem;
    letter-spacing: 0.01em;
  }

  .footer-custom__newsletter .newsletter__subheading {
    font-size: 1.3rem;
    line-height: 1.9;
    margin-bottom: 2rem;
  }

  .footer-custom__bottom {
    margin-top: 4rem;
    padding-top: 3.2rem;
  }

  .footer-custom__copyright {
    padding-top: 2.4rem;
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.6);
    display: flex;
    flex-wrap: wrap;
    gap: 1.6rem;
    align-items: center;
  }

  .footer-custom__copyright a {
    color: inherit;
    text-decoration: none;
  }

  .footer-custom__copyright a:hover {
    text-decoration: underline;
  }
{% endstylesheet %}

<footer class="footer-custom color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <div class="footer-custom__outer-grid">

      {%- comment -%} Column 1: Existing footer content {%- endcomment -%}
      <div class="footer-custom__main">
        <div class="footer-custom__grid">

          {%- comment -%} Sub-column 1: Store info {%- endcomment -%}
          <div class="footer-custom__col">
            {%- if section.settings.col1_heading != blank -%}
              <h2 class="footer-custom__heading">{{ section.settings.col1_heading | escape }}</h2>
            {%- endif -%}
            {%- if section.settings.col1_content != blank -%}
              <div class="footer-custom__address-wrapper">
                <div class="footer-custom__content rte">{{ section.settings.col1_content }}</div>
                <svg class="footer-custom__address-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
              </div>
            {%- endif -%}
          </div>

          {%- comment -%} Sub-column 2: Contact {%- endcomment -%}
          <div class="footer-custom__col">
            {%- if section.settings.col2_heading != blank -%}
              <h2 class="footer-custom__heading">{{ section.settings.col2_heading | escape }}</h2>
            {%- endif -%}
            {%- if section.settings.col2_content != blank -%}
              <div class="footer-custom__content rte">{{ section.settings.col2_content }}</div>
            {%- endif -%}
            {%- if section.settings.col2_link_label != blank and section.settings.col2_link_url != blank -%}
              <a href="{{ section.settings.col2_link_url }}" class="footer-custom__link">
                {{- section.settings.col2_link_label | escape -}}
              </a>
            {%- endif -%}
          </div>


        </div>
      </div>

      {%- comment -%} Column 2: Newsletter {%- endcomment -%}
      <div class="footer-custom__newsletter">
        {%- if section.settings.newsletter_heading != blank -%}
          <h2>{{ section.settings.newsletter_heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.newsletter_text != blank -%}
          <div class="newsletter__subheading rte">{{ section.settings.newsletter_text }}</div>
        {%- endif -%}
        {% form 'customer', class: 'newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="newsletter-form__field-wrapper">
            <div class="field">
              <input
                id="NewsletterForm--{{ section.id }}"
                type="email"
                name="contact[email]"
                class="field__input"
                value="{{ form.email }}"
                aria-required="true"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                {% if form.errors %}
                  autofocus
                  aria-invalid="true"
                  aria-describedby="Newsletter-error--{{ section.id }}"
                {% elsif form.posted_successfully? %}
                  aria-describedby="Newsletter-success--{{ section.id }}"
                {% endif %}
                placeholder="{{ 'newsletter.label' | t }}"
                required
              >
              <label class="field__label" for="NewsletterForm--{{ section.id }}">
                {{ 'newsletter.label' | t }}
              </label>
              <button
                type="submit"
                class="newsletter-form__button field__button"
                name="commit"
                id="Subscribe"
                aria-label="{{ 'newsletter.button_label' | t }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-arrow.svg' | inline_asset_content -}}
                </span>
              </button>
            </div>
            {%- if form.errors -%}
              <small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">
                <span class="svg-wrapper">
                  {{- 'icon-error.svg' | inline_asset_content -}}
                </span>
                {{- form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email -}}
              </small>
            {%- endif -%}
          </div>
          {%- if form.posted_successfully? -%}
            <h3
              class="newsletter-form__message newsletter-form__message--success form__message"
              id="Newsletter-success--{{ section.id }}"
              tabindex="-1"
              autofocus
            >
              <span class="svg-wrapper">
                {{- 'icon-success.svg' | inline_asset_content -}}
              </span>
              {{- 'newsletter.success' | t }}
            </h3>
          {%- endif -%}
        {% endform %}
      </div>

    </div>

    <div class="footer-custom__bottom">
      {%- if section.settings.bottom_link_label != blank and section.settings.bottom_link_url != blank -%}
        <a href="{{ section.settings.bottom_link_url }}" class="footer-custom__link" style="margin-top:0;">
          {{- section.settings.bottom_link_label | escape -}}
        </a>
      {%- endif -%}

      <div class="footer-custom__copyright">
        <small>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</small>
        {%- if section.settings.show_policy -%}
          {%- for policy in shop.policies -%}
            {%- if policy != blank -%}
              <small><a href="{{ policy.url }}">{{ policy.title | escape }}</a></small>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "div",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Column 1 — Store info"
    },
    {
      "type": "text",
      "id": "col1_heading",
      "label": "Heading",
      "default": "Galleri Helle Knudsen"
    },
    {
      "type": "richtext",
      "id": "col1_content",
      "label": "Content",
      "default": "<p>Hantverkargatan 18-20<br>112 21 Stockholm</p><p>Öppettider:<br>Tisdag - torsdag: 11-17.30<br>Fredag - lördag: 12-16</p>"
    },
    {
      "type": "header",
      "content": "Column 2 — Contact"
    },
    {
      "type": "text",
      "id": "col2_heading",
      "label": "Heading",
      "default": "Kontakt"
    },
    {
      "type": "richtext",
      "id": "col2_content",
      "label": "Content",
      "default": "<p><em>Helle Knudsen</em><br>info@gallerihelle.com<br>070-416 44 40</p>"
    },
    {
      "type": "text",
      "id": "col2_link_label",
      "label": "Link label",
      "default": "Fler kontaktuppgifter"
    },
    {
      "type": "url",
      "id": "col2_link_url",
      "label": "Link URL"
    },
{
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "WILDSTYLE NEWSLETTER"
    },
    {
      "type": "richtext",
      "id": "newsletter_text",
      "label": "Newsletter text",
      "default": "<p>Don't miss out on upcoming exhibitions and special offers</p>"
    },
    {
      "type": "header",
      "content": "Bottom link"
    },
    {
      "type": "text",
      "id": "bottom_link_label",
      "label": "Link label",
      "default": "Om galleriet"
    },
    {
      "type": "url",
      "id": "bottom_link_url",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Footer bottom"
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "label": "Show policy links",
      "default": true,
      "info": "Displays your store's policy pages (privacy, shipping, etc.) from Shopify admin."
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
