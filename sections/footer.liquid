{%- style -%}
  .footer-custom {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .footer-custom {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% stylesheet %}
  .footer-custom {
    border-top: none;
    margin-top: 12rem;
  }

  .footer-custom__outer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: start;
  }

  @media screen and (min-width: 750px) {
    .footer-custom__outer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
    }
  }

  .footer-custom__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 4rem;
    row-gap: 3.2rem;
    align-items: start;
  }

  @media screen and (max-width: 749px) {
    .footer-custom__grid {
      grid-template-columns: 1fr;
      gap: 3.2rem;
    }
  }

  .footer-custom__heading {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0 0 0.8rem;
    letter-spacing: 0.01em;
  }

  .footer-custom__content {
    font-size: 1.4rem;
    line-height: 1.5;
  }

  .footer-custom__content p {
    margin: 0;
  }

  .footer-custom__content p + p {
    margin-top: 0.8rem;
  }

  .footer-custom__menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-custom__menu li {
    margin-bottom: 1.2rem;
  }

  .footer-custom__menu li:last-child {
    margin-bottom: 0;
  }

  .footer-custom__menu-link {
    text-decoration: none;
    font-size: 1.4rem;
    font-weight: 400;
    color: rgba(var(--color-foreground), 0.7);
  }

  .footer-custom__menu-link:hover {
    color: rgb(var(--color-foreground));
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-custom__link {
    display: inline-block;
    margin-top: 1.6rem;
    font-size: 1.4rem;
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-custom__newsletter {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .footer-custom__newsletter .newsletter-form {
    align-items: flex-start;
    margin: 0;
  }

  .footer-custom__newsletter .newsletter-form__field-wrapper {
    max-width: 36rem;
  }

  .footer-custom__newsletter .newsletter__subheading {
    margin-left: 0;
    margin-right: 0;
  }

  .footer-custom__newsletter h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0 0 2rem;
    letter-spacing: 0.01em;
  }

  .footer-custom__newsletter .newsletter__subheading {
    font-size: 1.4rem;
    line-height: 1.5;
    margin-bottom: 2rem;
  }

  .footer-custom__hours-heading {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0 0 0.8rem;
  }

  .footer-custom__hours-row {
    display: flex;
    justify-content: space-between;
    gap: 1.6rem;
    font-size: 1.4rem;
    line-height: 1.5;
  }

  .footer-custom__hours-day {
    color: rgba(var(--color-foreground), 0.7);
  }

  .footer-custom__hours-time {
    color: rgba(var(--color-foreground), 0.7);
    text-align: right;
    white-space: nowrap;
  }

  .footer-custom__bottom {
    margin-top: 4rem;
    padding-top: 3.2rem;
  }

  .footer-custom__copyright {
    padding-top: 2.4rem;
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.5);
    display: flex;
    flex-wrap: wrap;
    gap: 1.6rem;
    align-items: center;
  }

  .footer-custom__copyright a {
    color: inherit;
    text-decoration: none;
  }

  .footer-custom__copyright a:hover {
    text-decoration: underline;
  }

  .footer-custom__social-list {
    display: flex;
    justify-content: flex-start !important;
    gap: 1.6rem;
    padding: 0;
    margin: 0;
  }

  .footer-custom__social-list .list-social__item {
    list-style: none;
  }

  .footer-custom__social-list .list-social__link {
    display: flex;
    align-items: flex-start;
    padding: 0 1.1rem 1.1rem 0;
    opacity: 0.7;
    transition: opacity 150ms ease;
  }

  .footer-custom__social-list .list-social__link:hover {
    opacity: 1;
  }

  .footer-custom__social-list .list-social__link .svg-wrapper svg {
    width: 28px;
    height: 28px;
  }
{% endstylesheet %}

<footer class="footer-custom color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <div class="footer-custom__outer-grid">

      {%- comment -%} Column 1: Existing footer content {%- endcomment -%}
      <div class="footer-custom__main">
        <div class="footer-custom__grid">

          {%- comment -%} Row 1, Col 1: Store info {%- endcomment -%}
          <div class="footer-custom__col">
            {%- if section.settings.col1_heading != blank -%}
              <h2 class="footer-custom__heading">{{ section.settings.col1_heading | escape }}</h2>
            {%- endif -%}
            {%- if section.settings.col1_content != blank -%}
              <div class="footer-custom__content rte">{{ section.settings.col1_content }}</div>
            {%- endif -%}
          </div>

          {%- comment -%} Row 1, Col 2: Contact {%- endcomment -%}
          <div class="footer-custom__col">
            {%- if section.settings.col2_heading != blank -%}
              <h2 class="footer-custom__heading">{{ section.settings.col2_heading | escape }}</h2>
            {%- endif -%}
            {%- if section.settings.col2_content != blank -%}
              <div class="footer-custom__content rte">{{ section.settings.col2_content }}</div>
            {%- endif -%}
            {%- if section.settings.col2_link_label != blank and section.settings.col2_link_url != blank -%}
              <a href="{{ section.settings.col2_link_url }}" class="footer-custom__link">
                {{- section.settings.col2_link_label | escape -}}
              </a>
            {%- endif -%}
          </div>

          {%- comment -%} Row 2, Col 1: Hours {%- endcomment -%}
          <div class="footer-custom__col">
            {%- assign has_hours = false -%}
            {%- for i in (1..5) -%}
              {%- assign day_key = 'hours_day_' | append: i -%}
              {%- assign time_key = 'hours_time_' | append: i -%}
              {%- if section.settings[day_key] != blank or section.settings[time_key] != blank -%}
                {%- assign has_hours = true -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if has_hours -%}
              {%- if section.settings.hours_heading != blank -%}
                <p class="footer-custom__hours-heading">{{ section.settings.hours_heading | escape }}</p>
              {%- endif -%}
              {%- for i in (1..5) -%}
                {%- assign day_key = 'hours_day_' | append: i -%}
                {%- assign time_key = 'hours_time_' | append: i -%}
                {%- if section.settings[day_key] != blank or section.settings[time_key] != blank -%}
                  <div class="footer-custom__hours-row">
                    <span class="footer-custom__hours-day">{{ section.settings[day_key] | escape }}</span>
                    <span class="footer-custom__hours-time">{{ section.settings[time_key] | escape }}</span>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          </div>

          {%- comment -%} Row 2, Col 2: Socials {%- endcomment -%}
          <div class="footer-custom__col">
            {%- if settings.social_facebook_link != blank or settings.social_instagram_link != blank or settings.social_youtube_link != blank or settings.social_tiktok_link != blank or settings.social_twitter_link != blank or settings.social_pinterest_link != blank -%}
              <h2 class="footer-custom__heading">{{ 'sections.footer.follow_us' | t }}</h2>
              {% render 'social-icons', class: 'footer-custom__social-list' %}
            {%- endif -%}
          </div>


        </div>
      </div>

      {%- comment -%} Column 2: Newsletter {%- endcomment -%}
      <div class="footer-custom__newsletter">
        {%- if section.settings.newsletter_heading != blank -%}
          <h2>{{ section.settings.newsletter_heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.newsletter_text != blank -%}
          <div class="newsletter__subheading rte">{{ section.settings.newsletter_text }}</div>
        {%- endif -%}
        {% form 'customer', class: 'newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="newsletter-form__field-wrapper">
            <div class="field">
              <input
                id="NewsletterForm--{{ section.id }}"
                type="email"
                name="contact[email]"
                class="field__input"
                value="{{ form.email }}"
                aria-required="true"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                {% if form.errors %}
                  autofocus
                  aria-invalid="true"
                  aria-describedby="Newsletter-error--{{ section.id }}"
                {% elsif form.posted_successfully? %}
                  aria-describedby="Newsletter-success--{{ section.id }}"
                {% endif %}
                placeholder="{{ 'newsletter.label' | t }}"
                required
              >
              <label class="field__label" for="NewsletterForm--{{ section.id }}">
                {{ 'newsletter.label' | t }}
              </label>
              <button
                type="submit"
                class="newsletter-form__button field__button"
                name="commit"
                id="Subscribe"
                aria-label="{{ 'newsletter.button_label' | t }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-arrow.svg' | inline_asset_content -}}
                </span>
              </button>
            </div>
            {%- if form.errors -%}
              <small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">
                <span class="svg-wrapper">
                  {{- 'icon-error.svg' | inline_asset_content -}}
                </span>
                {{- form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email -}}
              </small>
            {%- endif -%}
          </div>
          {%- if form.posted_successfully? -%}
            <h3
              class="newsletter-form__message newsletter-form__message--success form__message"
              id="Newsletter-success--{{ section.id }}"
              tabindex="-1"
              autofocus
            >
              {{- 'newsletter.success' | t }}
            </h3>
          {%- endif -%}
        {% endform %}
      </div>

    </div>

    <div class="footer-custom__bottom">
      {%- if section.settings.bottom_link_label != blank and section.settings.bottom_link_url != blank -%}
        <a href="{{ section.settings.bottom_link_url }}" class="footer-custom__link" style="margin-top:0;">
          {{- section.settings.bottom_link_label | escape -}}
        </a>
      {%- endif -%}

      <div class="footer-custom__copyright">
        <small>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</small>
        {%- if section.settings.show_policy -%}
          {%- for policy in shop.policies -%}
            {%- if policy != blank -%}
              <small><a href="{{ policy.url }}">{{ policy.title | escape }}</a></small>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ArtGallery",
      "name": {{ shop.name | json }},
      "url": {{ request.origin | json }},
      {%- if shop.description != blank -%}
        "description": {{ shop.description | json }},
      {%- endif -%}
      {%- if settings.logo -%}
        "image": {{ settings.logo | image_url: width: 1200 | prepend: "https:" | json }},
      {%- endif -%}
      "address": {
        "@type": "PostalAddress",
        "streetAddress": {{ section.settings.schema_street | default: '' | json }},
        "addressLocality": {{ section.settings.schema_city | default: '' | json }},
        "postalCode": {{ section.settings.schema_postal | default: '' | json }},
        "addressCountry": "SE"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": {{ section.settings.schema_lat | default: '57.7089' }},
        "longitude": {{ section.settings.schema_lng | default: '11.9746' }}
      }
      {%- if section.settings.schema_phone != blank -%}
        ,"telephone": {{ section.settings.schema_phone | json }}
      {%- endif -%}
      {%- if section.settings.schema_email != blank -%}
        ,"email": {{ section.settings.schema_email | json }}
      {%- endif -%}
      {%- assign has_schema_hours = false -%}
      {%- for i in (1..5) -%}
        {%- assign day_key = 'schema_hours_day_' | append: i -%}
        {%- assign time_key = 'schema_hours_open_' | append: i -%}
        {%- if section.settings[day_key] != blank and section.settings[time_key] != blank -%}
          {%- assign has_schema_hours = true -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if has_schema_hours -%}
        ,"openingHoursSpecification": [
          {%- assign hours_output = false -%}
          {%- for i in (1..5) -%}
            {%- assign day_key = 'schema_hours_day_' | append: i -%}
            {%- assign open_key = 'schema_hours_open_' | append: i -%}
            {%- assign close_key = 'schema_hours_close_' | append: i -%}
            {%- if section.settings[day_key] != blank and section.settings[open_key] != blank -%}
              {%- if hours_output -%},{%- endif -%}
              {
                "@type": "OpeningHoursSpecification",
                "dayOfWeek": {{ section.settings[day_key] | json }},
                "opens": {{ section.settings[open_key] | json }},
                "closes": {{ section.settings[close_key] | default: '' | json }}
              }
              {%- assign hours_output = true -%}
            {%- endif -%}
          {%- endfor -%}
        ]
      {%- endif -%}
    }
  </script>
</footer>

