{%- style -%}
  .footer-custom {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .footer-custom {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% stylesheet %}
  .footer-custom {
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
  }

  .footer-custom__grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 4rem;
  }

  @media screen and (max-width: 749px) {
    .footer-custom__grid {
      grid-template-columns: 1fr;
      gap: 3.2rem;
    }
  }

  .footer-custom__heading {
    font-size: 1.6rem;
    font-weight: 400;
    margin: 0 0 2rem;
    letter-spacing: 0.01em;
  }

  .footer-custom__content {
    font-size: 1.4rem;
    line-height: 1.9;
  }

  .footer-custom__content p {
    margin: 0;
  }

  .footer-custom__content p + p {
    margin-top: 0.8rem;
  }

  .footer-custom__menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-custom__menu li {
    margin-bottom: 1.2rem;
  }

  .footer-custom__menu li:last-child {
    margin-bottom: 0;
  }

  .footer-custom__menu-link {
    text-decoration: none;
    font-size: 1.4rem;
    color: inherit;
  }

  .footer-custom__menu-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-custom__link {
    display: inline-block;
    margin-top: 1.6rem;
    font-size: 1.4rem;
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-custom__bottom {
    margin-top: 4rem;
    padding-top: 3.2rem;
  }

  .footer-custom__copyright {
    padding-top: 2.4rem;
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.6);
    display: flex;
    flex-wrap: wrap;
    gap: 1.6rem;
    align-items: center;
  }

  .footer-custom__copyright a {
    color: inherit;
    text-decoration: none;
  }

  .footer-custom__copyright a:hover {
    text-decoration: underline;
  }
{% endstylesheet %}

<footer class="footer-custom color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <div class="footer-custom__grid">

      {%- comment -%} Column 1: Store info {%- endcomment -%}
      <div class="footer-custom__col">
        {%- if section.settings.col1_heading != blank -%}
          <h2 class="footer-custom__heading">{{ section.settings.col1_heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.col1_content != blank -%}
          <div class="footer-custom__content rte">{{ section.settings.col1_content }}</div>
        {%- endif -%}
      </div>

      {%- comment -%} Column 2: Contact {%- endcomment -%}
      <div class="footer-custom__col">
        {%- if section.settings.col2_heading != blank -%}
          <h2 class="footer-custom__heading">{{ section.settings.col2_heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.col2_content != blank -%}
          <div class="footer-custom__content rte">{{ section.settings.col2_content }}</div>
        {%- endif -%}
        {%- if section.settings.col2_link_label != blank and section.settings.col2_link_url != blank -%}
          <a href="{{ section.settings.col2_link_url }}" class="footer-custom__link">
            {{- section.settings.col2_link_label | escape -}}
          </a>
        {%- endif -%}
      </div>

      {%- comment -%} Column 3: Info menu from Shopify admin {%- endcomment -%}
      <div class="footer-custom__col">
        {%- if section.settings.col3_heading != blank -%}
          <h2 class="footer-custom__heading">{{ section.settings.col3_heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.col3_menu != blank -%}
          <ul class="footer-custom__menu">
            {%- for link in section.settings.col3_menu.links -%}
              <li>
                <a
                  href="{{ link.url }}"
                  class="footer-custom__menu-link{% if link.active %} footer-custom__menu-link--active{% endif %}"
                >
                  {{- link.title | escape -}}
                </a>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

    </div>

    <div class="footer-custom__bottom">
      {%- if section.settings.bottom_link_label != blank and section.settings.bottom_link_url != blank -%}
        <a href="{{ section.settings.bottom_link_url }}" class="footer-custom__link" style="margin-top:0;">
          {{- section.settings.bottom_link_label | escape -}}
        </a>
      {%- endif -%}

      <div class="footer-custom__copyright">
        <small>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</small>
        {%- if section.settings.show_policy -%}
          {%- for policy in shop.policies -%}
            {%- if policy != blank -%}
              <small><a href="{{ policy.url }}">{{ policy.title | escape }}</a></small>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "div",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Column 1 — Store info"
    },
    {
      "type": "text",
      "id": "col1_heading",
      "label": "Heading",
      "default": "Galleri Helle Knudsen"
    },
    {
      "type": "richtext",
      "id": "col1_content",
      "label": "Content",
      "default": "<p>Hantverkargatan 18-20<br>112 21 Stockholm</p><p>Öppettider:<br>Tisdag - torsdag: 11-17.30<br>Fredag - lördag: 12-16</p>"
    },
    {
      "type": "header",
      "content": "Column 2 — Contact"
    },
    {
      "type": "text",
      "id": "col2_heading",
      "label": "Heading",
      "default": "Kontakt"
    },
    {
      "type": "richtext",
      "id": "col2_content",
      "label": "Content",
      "default": "<p><em>Helle Knudsen</em><br>info@gallerihelle.com<br>070-416 44 40</p>"
    },
    {
      "type": "text",
      "id": "col2_link_label",
      "label": "Link label",
      "default": "Fler kontaktuppgifter"
    },
    {
      "type": "url",
      "id": "col2_link_url",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Column 3 — Info menu"
    },
    {
      "type": "text",
      "id": "col3_heading",
      "label": "Heading",
      "default": "Info"
    },
    {
      "type": "link_list",
      "id": "col3_menu",
      "label": "Menu",
      "default": "footer",
      "info": "Select the menu to display in this column. Manage menus in Shopify admin under Navigation."
    },
    {
      "type": "header",
      "content": "Bottom link"
    },
    {
      "type": "text",
      "id": "bottom_link_label",
      "label": "Link label",
      "default": "Om galleriet"
    },
    {
      "type": "url",
      "id": "bottom_link_url",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Footer bottom"
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "label": "Show policy links",
      "default": true,
      "info": "Displays your store's policy pages (privacy, shipping, etc.) from Shopify admin."
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
