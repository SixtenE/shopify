{% stylesheet %}
  .about-page {
    padding-top: var(--about-padding-top, 60px);
    padding-bottom: var(--about-padding-bottom, 60px);
  }

  .about-page__inner {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Hero area */
  .about-page__hero {
    margin-bottom: 4rem;
  }

  .about-page__title {
    font-size: 2.38rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: 0.01em;
    margin: 0 0 1.5rem;
  }

  .about-page__subtitle {
    font-size: 1.6rem;
    line-height: 1.5;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0;
    max-width: 680px;
  }

  /* Image */
  .about-page__image-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    margin-bottom: 4rem;
  }

  .about-page__image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-page__image-placeholder {
    background: rgba(var(--color-foreground), 0.04);
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(var(--color-foreground), 0.3);
    border-radius: 4px;
  }

  /* Content grid */
  .about-page__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-bottom: 4rem;
  }

  .about-page__block-heading {
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1.5;
    letter-spacing: 0.01em;
    margin: 0 0 1rem;
  }

  .about-page__block-text {
    font-size: 1.4rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0;
  }

  /* Info row */
  .about-page__info {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    border-top: 1px solid rgba(var(--color-foreground), 0.1);
    padding-top: 2.5rem;
  }

  .about-page__info-label {
    font-size: 1.2rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.5);
    margin: 0 0 0.5rem;
  }

  .about-page__info-value {
    font-size: 1.4rem;
    font-weight: 500;
    margin: 0;
    line-height: 1.5;
  }

  .about-page__info-value a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.3rem;
    text-decoration-thickness: 0.1rem;
  }

  @media screen and (max-width: 749px) {
    .about-page__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .about-page__info {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
{% endstylesheet %}

<div
  class="about-page color-{{ section.settings.color_scheme }} gradient"
  style="
    --about-padding-top: {{ section.settings.padding_top }}px;
    --about-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="about-page__inner">
    {%- comment -%} Hero heading {%- endcomment -%}
    <div class="about-page__hero">
      {%- if section.settings.title != blank -%}
        <h1 class="about-page__title">{{ section.settings.title | escape }}</h1>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="about-page__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Featured image {%- endcomment -%}
    {%- if section.settings.image != blank -%}
      <div class="about-page__image-wrapper" style="aspect-ratio: {{ section.settings.image_ratio }}">
        {{
          section.settings.image
          | image_url: width: 1800
          | image_tag:
            widths: '600, 900, 1200, 1800',
            sizes: '(max-width: 749px) calc(100vw - 3rem), calc(var(--page-width, 1200px) - 3rem)',
            loading: 'lazy'
        }}
      </div>
    {%- endif -%}

    {%- comment -%} Two-column content {%- endcomment -%}
    <div class="about-page__grid">
      <div>
        {%- if section.settings.block_1_heading != blank -%}
          <h2 class="about-page__block-heading">{{ section.settings.block_1_heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.block_1_text != blank -%}
          <p class="about-page__block-text">{{ section.settings.block_1_text }}</p>
        {%- endif -%}
      </div>
      <div>
        {%- if section.settings.block_2_heading != blank -%}
          <h2 class="about-page__block-heading">{{ section.settings.block_2_heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.block_2_text != blank -%}
          <p class="about-page__block-text">{{ section.settings.block_2_text }}</p>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Info row (location, hours, contact) {%- endcomment -%}
    {%- if section.settings.info_1_value != blank or section.settings.info_2_value != blank or section.settings.info_3_value != blank -%}
      <div class="about-page__info">
        {%- if section.settings.info_1_value != blank -%}
          <div>
            {%- if section.settings.info_1_label != blank -%}
              <p class="about-page__info-label">{{ section.settings.info_1_label | escape }}</p>
            {%- endif -%}
            <p class="about-page__info-value">{{ section.settings.info_1_value }}</p>
          </div>
        {%- endif -%}
        {%- if section.settings.info_2_value != blank -%}
          <div>
            {%- if section.settings.info_2_label != blank -%}
              <p class="about-page__info-label">{{ section.settings.info_2_label | escape }}</p>
            {%- endif -%}
            <p class="about-page__info-value">{{ section.settings.info_2_value }}</p>
          </div>
        {%- endif -%}
        {%- if section.settings.info_3_value != blank -%}
          <div>
            {%- if section.settings.info_3_label != blank -%}
              <p class="about-page__info-label">{{ section.settings.info_3_label | escape }}</p>
            {%- endif -%}
            <p class="about-page__info-value">{{ section.settings.info_3_value }}</p>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "About the gallery",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Wildstyle Gallery"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "A contemporary art space in Gothenburg dedicated to graffiti and street art culture. We showcase rotating exhibitions from leading artists pushing the boundaries of the medium."
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Featured image"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "16 / 9", "label": "Widescreen (16:9)" },
        { "value": "4 / 3", "label": "Landscape (4:3)" },
        { "value": "3 / 2", "label": "Classic (3:2)" },
        { "value": "21 / 9", "label": "Ultra-wide (21:9)" }
      ],
      "default": "16 / 9"
    },
    {
      "type": "header",
      "content": "Content — Left column"
    },
    {
      "type": "text",
      "id": "block_1_heading",
      "label": "Heading",
      "default": "The Space"
    },
    {
      "type": "textarea",
      "id": "block_1_text",
      "label": "Text",
      "default": "Wildstyle Gallery is a contemporary art space in Gothenburg dedicated to showcasing graffiti and street art in a gallery setting. Our space features rotating exhibitions from both established and emerging artists, offering a platform where urban art meets fine art presentation."
    },
    {
      "type": "header",
      "content": "Content — Right column"
    },
    {
      "type": "text",
      "id": "block_2_heading",
      "label": "Heading",
      "default": "Exhibitions"
    },
    {
      "type": "textarea",
      "id": "block_2_text",
      "label": "Text",
      "default": "We host solo and group exhibitions throughout the year, each carefully curated to highlight the depth and diversity of contemporary graffiti art. From large-scale canvases to limited edition prints, every show brings something new to discover."
    },
    {
      "type": "header",
      "content": "Info row"
    },
    {
      "type": "text",
      "id": "info_1_label",
      "label": "Info 1 label",
      "default": "Location"
    },
    {
      "type": "richtext",
      "id": "info_1_value",
      "label": "Info 1 value",
      "default": "<p>Gothenburg, Sweden</p>"
    },
    {
      "type": "text",
      "id": "info_2_label",
      "label": "Info 2 label",
      "default": "Hours"
    },
    {
      "type": "richtext",
      "id": "info_2_value",
      "label": "Info 2 value",
      "default": "<p>Thu–Fri 12–18<br/>Sat–Sun 12–16</p>"
    },
    {
      "type": "text",
      "id": "info_3_label",
      "label": "Info 3 label",
      "default": "Contact"
    },
    {
      "type": "richtext",
      "id": "info_3_value",
      "label": "Info 3 value",
      "default": "<p><a href=\"mailto:hello@wildstylegallery.se\">hello@wildstylegallery.se</a></p>"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "About the gallery"
    }
  ]
}
{% endschema %}
