{%- style -%}
  .artists-blog {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 749px) {
    .artists-blog {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
  }
{%- endstyle -%}

{%- paginate blog.articles by 12 -%}
  <div class="artists-blog page-width">
    <h1 class="artists-blog__title{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      {{ blog.title | escape }}
    </h1>

    <div class="artists-grid">
      {%- for article in blog.articles -%}
        <a
          href="{{ article.url }}"
          class="artist-card{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          aria-label="{{ article.title | escape }}"
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: {{ forloop.index }};"
          {% endif %}
        >
          <div class="artist-card__image-wrap">
            {%- if article.image -%}
              <img
                srcset="
                  {%- if article.image.width >= 400 -%}{{ article.image | image_url: width: 400 }} 400w,{%- endif -%}
                  {%- if article.image.width >= 600 -%}{{ article.image | image_url: width: 600 }} 600w,{%- endif -%}
                  {%- if article.image.width >= 800 -%}{{ article.image | image_url: width: 800 }} 800w,{%- endif -%}
                  {{ article.image | image_url: width: 600 }} 600w
                "
                src="{{ article.image | image_url: width: 600 }}"
                alt="{{ article.image.alt | default: article.title | escape }}"
                loading="lazy"
                width="{{ article.image.width }}"
                height="{{ article.image.height }}"
                class="artist-card__image"
              >
            {%- else -%}
              <div class="artist-card__image-placeholder">
                {{- 'image' | placeholder_svg_tag: 'placeholder-svg' -}}
              </div>
            {%- endif -%}
          </div>

          <div class="artist-card__body">
            <h2 class="artist-card__name">{{ article.title | escape }}</h2>
            {%- if article.excerpt.size > 0 or article.content.size > 0 -%}
              <p class="artist-card__bio">
                {%- if article.excerpt.size > 0 -%}
                  {{ article.excerpt | strip_html | truncatewords: 25 }}
                {%- else -%}
                  {{ article.content | strip_html | truncatewords: 25 }}
                {%- endif -%}
              </p>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      {%- render 'pagination', paginate: paginate -%}
    {%- endif -%}
  </div>
{%- endpaginate -%}

{% stylesheet %}
  .artists-blog__title {
    font-size: 2.38rem;
    font-weight: 700;
    line-height: 1.5;
    margin: 0 0 4.8rem;
  }

  .artists-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.4rem;
  }

  @media screen and (min-width: 990px) {
    .artists-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 3.2rem;
    }
  }

  @media screen and (max-width: 549px) {
    .artists-grid {
      grid-template-columns: 1fr;
    }
  }

  .artist-card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(15, 0, 0, 0.12);
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 150ms ease;
    background: rgb(var(--color-background));
  }

  @media (hover: hover) and (pointer: fine) {
    .artist-card:hover {
      border-color: #646262;
    }

    .artist-card:hover .artist-card__image {
      transform: scale(1.03);
    }
  }

  .artist-card__image-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: rgba(var(--color-foreground), 0.05);
  }

  .artist-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .artist-card__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.25;
  }

  .artist-card__image-placeholder svg {
    width: 64px;
    height: 64px;
  }

  .artist-card__body {
    padding: 2rem 2rem 2.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    flex: 1;
  }

  .artist-card__name {
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1.4;
    margin: 0;
  }

  .artist-card__bio {
    font-size: 1.3rem;
    font-weight: 400;
    line-height: 1.6;
    margin: 0;
    color: #9a9898;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Artists blog",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ]
}
{% endschema %}
