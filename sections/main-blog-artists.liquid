{%- style -%}
  .artists-blog {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 749px) {
    .artists-blog {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
  }
{%- endstyle -%}

{%- paginate blog.articles by 250 -%}
  <div class="artists-blog page-width">
    <h1 class="artists-blog__title{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      {{ blog.title | escape }}
    </h1>

    {%- assign sorted_articles = blog.articles | sort: 'title' -%}
    <div class="artists-grid">
      {%- for article in sorted_articles -%}
        <a
          href="{{ article.url }}"
          class="artist-card{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          aria-label="{{ article.title | escape }}"
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: {{ forloop.index }};"
          {% endif %}
        >
          <div class="artist-card__image-wrap">
            {%- if article.image -%}
              <img
                srcset="
                  {%- if article.image.width >= 400 -%}{{ article.image | image_url: width: 400 }} 400w,{%- endif -%}
                  {%- if article.image.width >= 600 -%}{{ article.image | image_url: width: 600 }} 600w,{%- endif -%}
                  {%- if article.image.width >= 800 -%}{{ article.image | image_url: width: 800 }} 800w,{%- endif -%}
                  {{ article.image | image_url: width: 600 }} 600w
                "
                src="{{ article.image | image_url: width: 600 }}"
                alt="{{ article.image.alt | default: article.title | escape }}"
                loading="lazy"
                width="{{ article.image.width }}"
                height="{{ article.image.height }}"
                class="artist-card__image"
              >
            {%- else -%}
              <div class="artist-card__image-placeholder">
                {{- 'image' | placeholder_svg_tag: 'placeholder-svg' -}}
              </div>
            {%- endif -%}
            <div class="artist-card__arrow-wrap">
              <svg class="artist-card__arrow" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </div>

          <div class="artist-card__body">
            <h2 class="artist-card__name">
              {{ article.title | escape }}
            </h2>
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      {%- render 'pagination', paginate: paginate -%}
    {%- endif -%}
  </div>
{%- endpaginate -%}

{% stylesheet %}
  .artists-blog__title {
    font-size: 2.38rem;
    font-weight: 700;
    line-height: 1.5;
    margin: 0 0 4.8rem;
  }

  .artists-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.4rem;
  }

  @media screen and (min-width: 990px) {
    .artists-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 3.2rem;
    }
  }

  @media screen and (max-width: 549px) {
    .artists-grid {
      grid-template-columns: 1fr;
    }
  }

  .artist-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: rgb(var(--color-background));
  }


  .artist-card__image-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: rgba(var(--color-foreground), 0.05);
    border-radius: 4px;
  }

  .artist-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 200ms ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    .artist-card:hover .artist-card__image {
      opacity: 0.8;
    }
  }

  .artist-card__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.25;
  }

  .artist-card__image-placeholder svg {
    width: 64px;
    height: 64px;
  }

  .artist-card__body {
    padding: 1.2rem 0 1.6rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .artist-card__name {
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1.4;
    margin: 0;
  }

  .artist-card__arrow-wrap {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    width: 3.2rem;
    height: 3.2rem;
    background: var(--ds-light, #fdfcfc);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .artist-card__arrow {
    color: var(--ds-dark, #201d1d);
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Artists blog",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ]
}
{% endschema %}
