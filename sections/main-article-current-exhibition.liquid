{{ 'section-blog-post.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .article-ce__layout {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 749px) {
    .article-ce__layout {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
  }
{%- endstyle -%}

<article class="article-template article-template--current-exhibition">
  <div class="article-ce__layout page-width">
    <div class="article-ce__left{% unless article.image %} article-ce__left--no-image{% endunless %}">
      <h1 class="article-ce__title{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{ article.title | escape }}
      </h1>
      {%- if article.image -%}
        <div class="article-ce__image{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
          {{
            article.image
            | image_url: width: 1200
            | image_tag:
              loading: 'eager',
              widths: '400, 600, 800, 1000, 1200',
              sizes: '(min-width: 990px) 50vw, 100vw',
              class: 'article-ce__img'
          }}
        </div>
      {%- endif -%}
    </div>

    <div class="article-ce__body">
      {%- if section.settings.show_date -%}
        <p class="article-ce__date caption-with-letter-spacing{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
          {{- article.published_at | time_tag: format: 'date' -}}
        </p>
      {%- endif -%}

      <div class="article-ce__content rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ article.content }}
      </div>
    </div>
  </div>

  {%- assign artist_collection = article.metafields.custom.artist_collection.value -%}
  {%- if artist_collection != blank and artist_collection.products_count > 0 -%}
    <div class="article-ce__artist-products page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <h2 class="article-ce__artist-products-heading">
        {{ section.settings.products_heading | default: 'Shop artwork' | escape }}
      </h2>
      <ul class="article-template__artist-products-grid list-unstyled" role="list">
        {%- for product in artist_collection.products limit: section.settings.products_to_show -%}
          <li>
            {%- render 'card-product',
              card_product: product,
              media_aspect_ratio: 'square',
              show_secondary_image: true,
              show_vendor: false,
              show_rating: false,
              lazy_load: true,
              skip_styles: forloop.index > 1,
              quick_add: false,
              section_id: section.id
            -%}
          </li>
        {%- endfor -%}
      </ul>
      {%- if section.settings.show_view_all and artist_collection.products_count > section.settings.products_to_show -%}
        <div class="article-template__artist-products-footer">
          <a href="{{ artist_collection.url }}" class="button button--secondary">
            {{ section.settings.view_all_label | default: 'View all' | escape }}
          </a>
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
</article>

<script type="application/ld+json">
  {{ article | structured_data }}
</script>

{% stylesheet %}
  .article-template--current-exhibition {
    margin: 0;
  }

  .article-ce__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: start;
  }

  .article-ce__left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .article-ce__left--no-image {
    grid-column: 1 / -1;
  }

  .article-ce__image {
    align-self: stretch;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    width: 100%;
  }

  .article-ce__img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    border-radius: var(--border-radius);
  }

  .article-ce__title {
    margin-top: 0;
    margin-bottom: 1.5rem;
  }

  .article-ce__date {
    display: block;
    margin-bottom: 3rem;
    color: rgba(var(--color-foreground), 0.5);
    text-transform: none;
    letter-spacing: 0.01em;
    font-size: 1.4rem;
  }

  .article-ce__content {
    margin-top: 3rem;
  }

  .article-ce__back {
    margin-top: 4rem;
  }

  @media screen and (max-width: 749px) {
    .article-ce__layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  .article-ce__artist-products {
    padding-top: 6rem;
    padding-bottom: 6rem;
  }

  .article-ce__artist-products-heading {
    margin-top: 0;
    margin-bottom: 3rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Exhibition article",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "default": false,
      "label": "Show date"
    },
    {
      "type": "text",
      "id": "products_heading",
      "label": "Products heading",
      "default": "Shop artwork"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show \"View all\" button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "\"View all\" label",
      "default": "View all"
    }
  ]
}
{% endschema %}
