{%- unless request.page_type == 'index' or request.page_type == 'cart' or request.page_type == 'list-collections' -%}
  <nav class="breadcrumbs page-width" aria-label="Breadcrumb">
    <ol class="breadcrumbs__list" style="list-style:none;display:flex;flex-wrap:wrap;gap:0.4rem 0;padding:1.2rem 0 0;margin:0;font-size:1.3rem;">
      <li>
        <a href="{{ routes.root_url }}" class="breadcrumbs__link">{{ 'general.breadcrumbs.home' | t | default: 'Home' }}</a>
      </li>

      {%- if request.page_type == 'product' -%}
        <li aria-hidden="true" style="margin:0 0.4rem;opacity:0.5;">/</li>
        <li>
          {%- if collection -%}
            <a href="{{ collection.url }}" class="breadcrumbs__link">{{ collection.title | escape }}</a>
          {%- else -%}
            <a href="{{ routes.all_products_collection_url }}" class="breadcrumbs__link">{{ 'sections.collection_template.title' | t | default: 'Products' }}</a>
          {%- endif -%}
        </li>
        <li aria-hidden="true" style="margin:0 0.4rem;opacity:0.5;">/</li>
        <li aria-current="page">{{ product.title | escape }}</li>

      {%- elsif request.page_type == 'collection' -%}
        <li aria-hidden="true" style="margin:0 0.4rem;opacity:0.5;">/</li>
        <li aria-current="page">{{ collection.title | escape }}</li>

      {%- elsif request.page_type == 'article' -%}
        <li aria-hidden="true" style="margin:0 0.4rem;opacity:0.5;">/</li>
        <li>
          <a href="{{ blog.url }}" class="breadcrumbs__link">{{ blog.title | escape }}</a>
        </li>
        <li aria-hidden="true" style="margin:0 0.4rem;opacity:0.5;">/</li>
        <li aria-current="page">{{ article.title | escape }}</li>

      {%- elsif request.page_type == 'blog' -%}
        <li aria-hidden="true" style="margin:0 0.4rem;opacity:0.5;">/</li>
        <li aria-current="page">{{ blog.title | escape }}</li>

      {%- elsif request.page_type == 'page' -%}
        <li aria-hidden="true" style="margin:0 0.4rem;opacity:0.5;">/</li>
        <li aria-current="page">{{ page.title | escape }}</li>

      {%- elsif request.page_type == 'search' -%}
        <li aria-hidden="true" style="margin:0 0.4rem;opacity:0.5;">/</li>
        <li aria-current="page">{{ 'general.search.title' | t | default: 'Search' }}</li>
      {%- endif -%}
    </ol>
  </nav>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": {{ 'general.breadcrumbs.home' | t | default: 'Home' | json }},
          "item": "{{ request.origin }}{{ routes.root_url }}"
        }
        {%- if request.page_type == 'product' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            {%- if collection -%}
              "name": {{ collection.title | json }},
              "item": "{{ request.origin }}{{ collection.url }}"
            {%- else -%}
              "name": {{ 'sections.collection_template.title' | t | default: 'Products' | json }},
              "item": "{{ request.origin }}{{ routes.all_products_collection_url }}"
            {%- endif -%}
          }
          ,{
            "@type": "ListItem",
            "position": 3,
            "name": {{ product.title | json }}
          }

        {%- elsif request.page_type == 'collection' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ collection.title | json }}
          }

        {%- elsif request.page_type == 'article' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ blog.title | json }},
            "item": "{{ request.origin }}{{ blog.url }}"
          }
          ,{
            "@type": "ListItem",
            "position": 3,
            "name": {{ article.title | json }}
          }

        {%- elsif request.page_type == 'blog' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ blog.title | json }}
          }

        {%- elsif request.page_type == 'page' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ page.title | json }}
          }
        {%- endif -%}
      ]
    }
  </script>
{%- endunless -%}
